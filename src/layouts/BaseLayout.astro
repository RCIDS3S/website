---
import "../styles/global.css";
import identity from "../data/site/identity.json";

interface Props {
  title?: string;
  description?: string;
}

const { title = identity.title, description = identity.description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/assets/images/s3s-logo-temporary.jpg" />
    <link rel="apple-touch-icon" href="/assets/images/s3s-logo-temporary.jpg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script src="/scripts/navigation.js" is:inline></script>
  </body>
</html>
