---
import "../styles/global.css";
import identity from "../data/site/identity.json";

interface Props {
  title?: string;
  description?: string;
}

const { title = identity.title, description = identity.description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      const identity = window.netlifyIdentity;

      if (identity) {
        const openIdentityFromHash = () => {
          const hash = window.location.hash;

          if (hash.includes("invite_token") || hash.includes("confirmation_token")) {
            identity.open("signup");
          }

          if (hash.includes("recovery_token")) {
            identity.open("login");
          }
        };

        identity.on("init", (user) => {
          if (!user) {
            openIdentityFromHash();
          }
        });

        window.addEventListener("hashchange", openIdentityFromHash);
        window.setTimeout(openIdentityFromHash, 500);
      }
    </script>
    <script src="/scripts/navigation.js" is:inline></script>
  </body>
</html>
