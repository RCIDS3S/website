---
import BaseLayout from "../layouts/BaseLayout.astro";
import identity from "../data/site/identity.json";
import archive from "../data/archive/posts.json";
import archiveSettings from "../data/archive/settings.json";

const posts = archive.items;
const categories = Array.from(new Set(posts.flatMap((post) => post.categories))).sort((a, b) => a.localeCompare(b));
const years = Array.from(new Set(posts.map((post) => post.year))).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title={`${archiveSettings.metaTitle} | ${identity.title}`} description={archiveSettings.metaDescription}>
  <a class="skip-link" href="#archive-main">{archiveSettings.skipLinkText}</a>

  <header class="site-header">
    <a class="brand" href="/" aria-label={`${identity.title} home`}>
      <img src="/assets/images/third-sophistic.png" alt="" width="48" height="48" />
      <span>
        <strong>{identity.title}</strong>
        <small>{identity.subtitle}</small>
      </span>
    </a>
    <nav class="site-nav" aria-label={archiveSettings.navigationLabel}>
      {archiveSettings.navLinks.map((link) => <a href={link.url}>{link.label}</a>)}
    </nav>
  </header>

  <main id="archive-main">
    <section class="archive-hero">
      <p class="eyebrow">{archiveSettings.hero.kicker}</p>
      <h1>{archiveSettings.hero.title}</h1>
      <p class="dek">{archiveSettings.hero.text}</p>
    </section>

    <section class="archive-tools" aria-label={archiveSettings.filters.ariaLabel}>
      <label>
        {archiveSettings.filters.searchLabel}
        <input id="archive-search" type="search" placeholder={archiveSettings.filters.searchPlaceholder} />
      </label>
      <label>
        {archiveSettings.filters.categoryLabel}
        <select id="archive-category">
          <option value="">{archiveSettings.filters.allCategoriesLabel}</option>
          {categories.map((category) => <option value={category}>{category}</option>)}
        </select>
      </label>
      <label>
        {archiveSettings.filters.yearLabel}
        <select id="archive-year">
          <option value="">{archiveSettings.filters.allYearsLabel}</option>
          {years.map((year) => <option value={year}>{year}</option>)}
        </select>
      </label>
    </section>

    <section class="archive-results" aria-live="polite">
      <p class="archive-count"><span id="archive-count">{posts.length}</span> {archiveSettings.results.countSuffix}</p>
      <div class="archive-list" id="archive-list">
        {
          posts.map((post) => (
            <article
              class="archive-card"
              data-title={post.title.toLowerCase()}
              data-excerpt={post.excerpt.toLowerCase()}
              data-categories={post.categories.join(" ").toLowerCase()}
              data-category-list={post.categories.join("|")}
              data-year={post.year}
            >
              <div class="archive-card__meta">
                <time datetime={post.date}>{post.date}</time>
                <span>{post.categories.join(" / ")}</span>
              </div>
              <h2><a href={post.url} target="_blank" rel="noreferrer">{post.title}</a></h2>
              {post.excerpt && <p>{post.excerpt}</p>}
            </article>
          ))
        }
      </div>
    </section>
  </main>

  <script is:inline>
    const search = document.querySelector("#archive-search");
    const category = document.querySelector("#archive-category");
    const year = document.querySelector("#archive-year");
    const cards = Array.from(document.querySelectorAll(".archive-card"));
    const count = document.querySelector("#archive-count");

    const filterArchive = () => {
      const query = search.value.trim().toLowerCase();
      const selectedCategory = category.value;
      const selectedYear = year.value;
      let visible = 0;

      cards.forEach((card) => {
        const haystack = `${card.dataset.title} ${card.dataset.excerpt} ${card.dataset.categories}`;
        const categoryList = card.dataset.categoryList.split("|");
        const matchesQuery = !query || haystack.includes(query);
        const matchesCategory = !selectedCategory || categoryList.includes(selectedCategory);
        const matchesYear = !selectedYear || card.dataset.year === selectedYear;
        const show = matchesQuery && matchesCategory && matchesYear;

        card.hidden = !show;
        if (show) visible += 1;
      });

      count.textContent = String(visible);
    };

    [search, category, year].forEach((control) => control.addEventListener("input", filterArchive));
  </script>
</BaseLayout>
