---
import BaseLayout from "../layouts/BaseLayout.astro";
import identity from "../data/site/identity.json";
import navigation from "../data/site/navigation.json";
import hero from "../data/site/hero.json";
import studentDesk from "../data/site/student-desk.json";
import contact from "../data/site/contact.json";
import footer from "../data/site/footer.json";
import quickLinks from "../data/quick-links.json";
import events from "../data/events.json";
import resources from "../data/resources.json";
import officers from "../data/officers.json";
import about from "../data/about.json";

const externalLinkAttrs = { target: "_blank", rel: "noreferrer" };
---

<BaseLayout>
  <a class="skip-link" href="#main">{identity.skipLinkText}</a>

  <header class="site-header">
    <a class="brand" href="#home" aria-label={`${identity.title} home`}>
      <img src="/assets/images/third-sophistic.png" alt="" width="48" height="48" />
      <span>
        <strong>{identity.title}</strong>
        <small>{identity.subtitle}</small>
      </span>
    </a>
    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav class="site-nav" id="site-nav" aria-label="Primary navigation">
      <a href="#events">{navigation.eventsText}</a>
      <a href="#resources">{navigation.resourcesText}</a>
      <a href="#officers">{navigation.officersText}</a>
      <a href="#about">{navigation.aboutText}</a>
      <a href="#contact">{navigation.contactText}</a>
    </nav>
  </header>

  <main id="main">
    <section class="hero" id="home" aria-labelledby="hero-title">
      <div class="hero-copy">
        <p class="eyebrow">{hero.eyebrow}</p>
        <h1 id="hero-title">{hero.title}</h1>
        <p class="dek">{hero.text}</p>
        <div class="hero-actions">
          <a class="button primary" href={hero.primaryActionUrl}>{hero.primaryActionText}</a>
          <a class="button" href={hero.secondaryActionUrl}>{hero.secondaryActionText}</a>
        </div>
      </div>

      <aside class="status-board" aria-label="Student quick links">
        <div class="board-heading">
          <span>{studentDesk.label}</span>
          <strong>{studentDesk.term}</strong>
        </div>
        {
          quickLinks.items.map((link) => (
            <a href={link.url} {...externalLinkAttrs}>
              <span>{link.label}</span>
              <strong>{link.title}</strong>
            </a>
          ))
        }
      </aside>
    </section>

    <section class="section next-up" id="events" aria-labelledby="events-title">
      <div class="section-kicker">{events.kicker}</div>
      <div class="section-heading">
        <h2 id="events-title">{events.title}</h2>
        <p>{events.text}</p>
      </div>

      <div class="event-strip" aria-label="Featured events">
        {
          events.items.map((event) => (
            <article class="event-card">
              <time datetime={event.datetime}>{event.date}</time>
              <h3>{event.title}</h3>
              <p>{event.description}</p>
              <span>{event.status}</span>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section resource-section" id="resources" aria-labelledby="resources-title">
      <div class="section-kicker">{resources.kicker}</div>
      <div class="section-heading">
        <h2 id="resources-title">{resources.title}</h2>
        <p>{resources.text}</p>
      </div>

      <div class="resource-grid">
        {
          resources.items.map((resource) => {
            const isExternal = resource.url.startsWith("http");
            return (
              <a
                class:list={["resource-link", resource.style === "muted" && "muted-link"]}
                href={resource.url}
                {...(isExternal ? externalLinkAttrs : {})}
              >
                <span>{resource.label}</span>
                <strong>{resource.title}</strong>
                <p>{resource.description}</p>
              </a>
            );
          })
        }
      </div>
    </section>

    <section class="section officers-section" id="officers" aria-labelledby="officers-title">
      <div class="section-kicker">{officers.kicker}</div>
      <div class="section-heading">
        <h2 id="officers-title">{officers.title}</h2>
        <p>{officers.text}</p>
      </div>

      <div class="officer-layout">
        {
          officers.items.map((officer) => (
            <article class="officer-card">
              {officer.showRole !== false && <span>{officer.role}</span>}
              <h3>{officer.name}</h3>
              <p>{officer.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section about-section" id="about" aria-labelledby="about-title">
      <div class="section-kicker">{about.kicker}</div>
      <div class="about-copy">
        <h2 id="about-title">{about.title}</h2>
        {about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>

    <section class="section contact-section" id="contact" aria-labelledby="contact-title">
      <div class="section-kicker">{contact.kicker}</div>
      <div class="contact-panel">
        <div>
          <h2 id="contact-title">{contact.title}</h2>
          <p>{contact.text}</p>
        </div>
        <div class="contact-actions">
          <a class="button primary" href={`mailto:${contact.email}`}>{contact.emailButtonText}</a>
          <a class="button" href={contact.socialUrl} {...externalLinkAttrs}>{contact.socialButtonText}</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <span>{identity.title}</span>
    <span>{footer.text}</span>
  </footer>
</BaseLayout>
