---
import BaseLayout from "../layouts/BaseLayout.astro";
import identity from "../data/site/identity.json";
import contact from "../data/site/contact.json";
import opportunities from "../data/opportunities.json";
import opportunityUi from "../data/opportunities-ui.json";
import sources from "../data/opportunity-sources.json";

const now = new Date();
const items = opportunities.items
  .map((item) => {
    const deadline = item.deadline ? new Date(`${item.deadline}T23:59:59-04:00`) : null;
    const days = deadline ? Math.ceil((deadline.getTime() - now.getTime()) / 86400000) : null;
    let urgency = "rolling";
    let label = item.deadlineType || opportunityUi.dateLabels.rolling;

    if (typeof days === "number") {
      if (days < 0) {
        urgency = "closed";
        label = opportunityUi.dateLabels.closed;
      } else if (days <= 7) {
        urgency = "urgent";
        label = `${days} ${opportunityUi.dateLabels.daysSuffix}`;
      } else if (days <= 30) {
        urgency = "soon";
        label = `${days} ${opportunityUi.dateLabels.daysSuffix}`;
      } else {
        urgency = "open";
        label = `${days} ${opportunityUi.dateLabels.daysSuffix}`;
      }
    }

    return {
      ...item,
      days,
      urgency,
      deadlineLabel: label,
      searchText: `${item.title} ${item.type} ${item.source} ${item.fields.join(" ")} ${item.excerpt} ${item.fullDescription || ""} ${item.relevance}`.toLowerCase()
    };
  })
  .sort((a, b) => {
    const aDays = typeof a.days === "number" ? a.days : 9999;
    const bDays = typeof b.days === "number" ? b.days : 9999;
    return aDays - bDays;
  });

const fieldOptions = Array.from(new Set(items.flatMap((item) => item.fields))).sort((a, b) => a.localeCompare(b));
const typeOptions = Array.from(new Set(items.map((item) => item.type))).sort((a, b) => a.localeCompare(b));
const urgentCount = items.filter((item) => item.urgency === "urgent").length;
const soonCount = items.filter((item) => item.urgency === "soon").length;
const activeSources = sources.items.filter((source) => source.parser !== "officialWatch");
const watchSources = sources.items.filter((source) => source.parser === "officialWatch");
const purposeOptions = opportunityUi.purposeOptions;
const groups = [
  {
    id: "due-soon",
    title: opportunityUi.groups.dueSoon.title,
    text: opportunityUi.groups.dueSoon.text,
    filterType: "",
    filterField: "",
    filterQuery: "",
    items: items.filter((item) => typeof item.days === "number" && item.days <= 14)
  },
  {
    id: "media-art",
    title: opportunityUi.groups.mediaArt.title,
    text: opportunityUi.groups.mediaArt.text,
    filterType: "",
    filterField: "Film / Media",
    filterQuery: "",
    items: items.filter((item) => typeof item.days !== "number" || item.days > 14).filter((item) => /film|media|art|festival|exhibition/i.test(`${item.type} ${item.fields.join(" ")}`))
  },
  {
    id: "publications",
    title: opportunityUi.groups.publications.title,
    text: opportunityUi.groups.publications.text,
    filterType: "",
    filterField: "Publication",
    filterQuery: "",
    items: items.filter((item) => typeof item.days !== "number" || item.days > 14).filter((item) => /journal|collection|publication|chapter/i.test(item.type))
  },
  {
    id: "conferences",
    title: opportunityUi.groups.conferences.title,
    text: opportunityUi.groups.conferences.text,
    filterType: "Conference CFP",
    filterField: "",
    filterQuery: "",
    items: items.filter((item) => typeof item.days !== "number" || item.days > 14).filter((item) => /conference|cfp|seminar|symposium|workshop|panel/i.test(item.type) && !/journal|collection|publication|chapter/i.test(item.type))
  },
  {
    id: "funding",
    title: opportunityUi.groups.funding.title,
    text: opportunityUi.groups.funding.text,
    filterType: "",
    filterField: "Funding",
    filterQuery: "",
    items: items.filter((item) => typeof item.days !== "number" || item.days > 14).filter((item) => /grant|fellowship|funding/i.test(`${item.type} ${item.fields.join(" ")}`))
  }
]
  .map((group, index, allGroups) => {
    const previous = new Set(allGroups.slice(0, index).flatMap((entry) => entry.items.map((item) => item.sourceUrl)));
    return {
      ...group,
      items: group.items.filter((item) => !previous.has(item.sourceUrl))
    };
  })
  .filter((group) => group.items.length);

const displayPreview = (excerpt: unknown) => {
  const value = String(excerpt || "").trim().replace(/\s+/g, " ");
  if (!value) return "";
  const shortened = value.length > 300 ? `${value.slice(0, 297).trimEnd()}...` : value;
  return /(?:[.!?]|\.\.\.)["')\]]?$/.test(shortened) ? shortened : `${shortened}...`;
};

const detailText = (item: typeof items[number]) => String(item.fullDescription || item.excerpt || "").trim();

const signalTags = (item: typeof items[number]) => {
  const text = `${item.title} ${item.type} ${item.fields.join(" ")} ${item.excerpt} ${item.fullDescription || ""}`.toLowerCase();
  const tags = new Set<string>();
  const add = (label: string, pattern: RegExp) => {
    if (pattern.test(text)) tags.add(label);
  };

  add("Rhetoric", /rhetoric|rhetorical|composition|writing studies/);
  add("Tech Comm", /technical communication|technical writing|professional communication|documentation|content strategy/);
  add("AI", /\bai\b|artificial intelligence|machine learning|llm|generative/);
  add("Media Studies", /media studies|media theory|television|cinema|film/);
  add("Creative Practice", /film festival|screenplay|screenwriting|video art|exhibition|artist|creative practice/);
  add("Digital Humanities", /digital humanities|humanities computing|digital culture|computational/);
  add("Graduate-Friendly", /graduate|postgraduate|student|emerging scholar/);
  add("Funding", /grant|fellowship|funding|award|stipend/);
  if (/journal|edited collection|publication|chapter/i.test(String(item.type || "")) || /special issue|edited collection|call for chapters/i.test(text)) tags.add("Publication");
  add("Conference", /conference|cfp|symposium|workshop|panel|seminar/);

  item.fields.slice(0, 3).forEach((field) => tags.add(field));
  return Array.from(tags).slice(0, 6);
};

const signalQuery = (tag: string) => ({
  "Tech Comm": "technical communication",
  "Media Studies": "media",
  "Creative Practice": "creative",
  "Digital Humanities": "digital humanities",
  "Graduate-Friendly": "graduate",
  "Film / Media": "film",
  "Digital Humanities / Design": "digital",
  "Art / Media Practice": "art media"
}[tag] || tag);

const matchReasons = (item: typeof items[number]) => {
  const tags = signalTags(item).slice(0, 4);
  if (tags.length) return `${opportunityUi.generatedInsights.matchedBecausePrefix} ${tags.join(", ")}.`;
  return opportunityUi.generatedInsights.matchedFallback;
};

const detailChecklist = (item: typeof items[number]) => {
  const text = detailText(item);
  const lines = [];
  const lengthMatch = text.match(/(?:\d{2,4}[- ]?word|\d{1,2}[- ]?page|abstracts? of [^.]{0,80}|proposals? should [^.]{0,100})/i);
  const formatMatch = text.match(/(?:single papers?|panels?|roundtables?|workshops?|alternative formats?|screenplays?|films?|videos?)[^.]{0,120}/i);
  const contactMatch = text.match(/[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}/i);

  if (lengthMatch) lines.push(`${opportunityUi.generatedInsights.submissionShapePrefix} ${lengthMatch[0].trim()}`);
  if (formatMatch) lines.push(`${opportunityUi.generatedInsights.formatsMentionedPrefix} ${formatMatch[0].trim()}`);
  if (contactMatch) lines.push(`${opportunityUi.generatedInsights.contactPrefix} ${contactMatch[0].trim()}`);
  return lines.slice(0, 4);
};

const formatShortDate = (value: unknown) => {
  if (!value) return "";
  const match = String(value).match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (!match) return String(value);
  const [, year, month, day] = match;
  const date = new Date(Number(year), Number(month) - 1, Number(day));
  return date.toLocaleDateString("en-US", { month: "short", day: "numeric" });
};

const formatDaysLeft = (days: unknown) => {
  if (typeof days !== "number") return opportunityUi.dateLabels.rolling;
  if (days < 0) return opportunityUi.dateLabels.closed;
  if (days === 0) return opportunityUi.dateLabels.today;
  if (days === 1) return opportunityUi.dateLabels.oneDay;
  return `${days} ${opportunityUi.dateLabels.daysSuffix}`;
};

const formatDeadlineLabel = (value: unknown, type: unknown) => {
  const label = String(value || "").trim().toLowerCase();
  const kind = String(type || "").trim().toLowerCase();
  if (!label) return opportunityUi.dateLabels.deadline;
  if (label.includes("final")) return opportunityUi.dateLabels.finalDeadline;
  if (label.includes("early")) return opportunityUi.dateLabels.earlyDeadline;
  if (label.includes("next")) return opportunityUi.dateLabels.nextDeadline;
  if (label.includes("application")) return opportunityUi.dateLabels.applicationDue;
  if (label.includes("proposal")) return opportunityUi.dateLabels.proposalDue;
  if (label.includes("abstract")) return opportunityUi.dateLabels.proposalDue;
  if (label.includes("submission") || kind.includes("journal") || kind.includes("film festival")) return opportunityUi.dateLabels.submissionDue;
  if (label.includes("deadline")) return opportunityUi.dateLabels.deadline;
  return `${label.charAt(0).toUpperCase()}${label.slice(1)} ${opportunityUi.dateLabels.dueSuffix}`;
};

const locationPatterns = [
  { pattern: /newport,\s*(ri|rhode island)|newport rhode island|salve regina/i, label: "Newport, RI", lat: 41.49, lng: -71.31 },
  { pattern: /seattle|pamla/i, label: "Seattle, WA", lat: 47.61, lng: -122.33 },
  { pattern: /dallas|university of texas at dallas/i, label: "Dallas, TX", lat: 32.78, lng: -96.8 },
  { pattern: /las vegas/i, label: "Las Vegas, NV", lat: 36.17, lng: -115.14 },
  { pattern: /philadelphia|renaissance society of america/i, label: "Philadelphia, PA", lat: 39.95, lng: -75.17 },
  { pattern: /rochester/i, label: "Rochester, NY", lat: 43.16, lng: -77.61 },
  { pattern: /austin/i, label: "Austin, TX", lat: 30.27, lng: -97.74 },
  { pattern: /park city|sundance/i, label: "Park City, UT", lat: 40.65, lng: -111.5 },
  { pattern: /los angeles|csula|california state university los angeles/i, label: "Los Angeles, CA", lat: 34.05, lng: -118.24 },
  { pattern: /guelph/i, label: "Guelph, Canada", lat: 43.54, lng: -80.25 },
  { pattern: /providence|brown university/i, label: "Providence, RI", lat: 41.82, lng: -71.41 },
  { pattern: /cambridge/i, label: "Cambridge, UK", lat: 52.2, lng: 0.12 },
  { pattern: /lancaster university|lancaster,\s*uk/i, label: "Lancaster, UK", lat: 54.01, lng: -2.79 },
  { pattern: /liverpool/i, label: "Liverpool, UK", lat: 53.41, lng: -2.99 },
  { pattern: /munich|lmu munich/i, label: "Munich, Germany", lat: 48.14, lng: 11.58 },
  { pattern: /vienna/i, label: "Vienna, Austria", lat: 48.21, lng: 16.37 },
  { pattern: /lisbon/i, label: "Lisbon, Portugal", lat: 38.72, lng: -9.14 },
  { pattern: /rotterdam/i, label: "Rotterdam, Netherlands", lat: 51.92, lng: 4.48 },
  { pattern: /adelaide/i, label: "Adelaide, Australia", lat: -34.93, lng: 138.6 },
  { pattern: /hong kong/i, label: "Hong Kong", lat: 22.32, lng: 114.17 },
  { pattern: /south korea|chungbuk/i, label: "South Korea", lat: 36.63, lng: 127.49 },
  { pattern: /kolkata|adamas university|st\.?\s*xavier/i, label: "Kolkata, India", lat: 22.57, lng: 88.36 },
  { pattern: /bhopal|jagran lakecity/i, label: "Bhopal, India", lat: 23.26, lng: 77.41 },
  { pattern: /faisalabad/i, label: "Faisalabad, Pakistan", lat: 31.45, lng: 73.14 },
  { pattern: /brunei/i, label: "Brunei", lat: 4.54, lng: 114.73 },
  { pattern: /south africa|zululand|kwazulu/i, label: "KwaZulu-Natal, South Africa", lat: -28.53, lng: 30.9 },
  { pattern: /arizona state|tempe/i, label: "Tempe, AZ", lat: 33.43, lng: -111.94 },
  { pattern: /washington,\s*dc|washington dc/i, label: "Washington, DC", lat: 38.91, lng: -77.04 }
];

const isPhysicalEventCandidate = (item: typeof items[number]) => {
  const text = [
    item.type,
    item.title,
    item.location,
    item.excerpt,
    item.fullDescription
  ].filter(Boolean).join(" ");

  if (/journal|edited collection|book chapter|collection of essays|special issue|publication/i.test(String(item.type || ""))) {
    return false;
  }

  if (/virtual only|online only|remote only|virtual session|delivered via zoom regardless/i.test(text)) {
    return false;
  }

  return /conference|convention|festival|symposium|workshop|summit|colloquium|seminar|roundtable|panel|session|exhibition|biennial/i.test(text);
};

const projectMapPoint = (lat: number, lng: number) => ({
  lat,
  lng,
  x: Math.max(4, Math.min(96, ((lng + 180) / 360) * 100)),
  y: Math.max(6, Math.min(94, ((90 - lat) / 180) * 100))
});

const mapPointForItem = (item: typeof items[number]) => {
  if (!isPhysicalEventCandidate(item)) return null;
  const location = String(item.location || "").trim();
  if (!location || /^(cfplist|n\/a)$/i.test(location)) return null;
  if (/virtual|online|remote/i.test(location)) {
    return null;
  }

  const match = locationPatterns.find((entry) => entry.pattern.test(location));
  if (!match) return null;
  return { ...projectMapPoint(match.lat, match.lng), label: match.label, virtual: false };
};

const mappedOpportunities = items
  .map((item, index) => {
    const point = mapPointForItem(item);
    if (!point) return null;
    return { item, point, id: `map-item-${index}` };
  })
  .filter((entry) => entry !== null)
  .slice(0, 80);

const physicalMapOpportunities = mappedOpportunities.filter((entry) => !entry.point.virtual);
const virtualMapCount = mappedOpportunities.length - physicalMapOpportunities.length;
const physicalMapPlaceMap = new Map<string, {
  label: string;
  lat: number;
  lng: number;
  x: number;
  y: number;
  items: typeof physicalMapOpportunities;
}>();

physicalMapOpportunities.forEach((entry) => {
  const existing = physicalMapPlaceMap.get(entry.point.label);
  if (existing) {
    existing.items.push(entry);
  } else {
    physicalMapPlaceMap.set(entry.point.label, {
      label: entry.point.label,
      lat: entry.point.lat,
      lng: entry.point.lng,
      x: entry.point.x,
      y: entry.point.y,
      items: [entry]
    });
  }
});

const physicalMapPlaces = Array.from(physicalMapPlaceMap.values())
  .sort((a, b) => b.items.length - a.items.length || a.label.localeCompare(b.label))
  .map((place, index) => ({ ...place, id: `map-place-${index}` }));

const physicalMapPlacesJson = JSON.stringify(physicalMapPlaces.map((place) => ({
  id: place.id,
  label: place.label,
  lat: place.lat,
  lng: place.lng,
  count: place.items.length,
  calls: place.items.slice(0, 3).map((entry) => ({
    title: entry.item.title,
    url: entry.item.sourceUrl
  }))
})));
const opportunityUiJson = JSON.stringify(opportunityUi).replace(/</g, "\\u003c");

const copyDetails = (item: typeof items[number]) => [
  item.title,
  `${item.source} / ${item.type}`,
  item.deadline ? `${formatDeadlineLabel(item.deadlineType, item.type)}: ${item.deadline}` : `${opportunityUi.dialog.deadlineFallback}: ${opportunityUi.cards.sourceListedFallback}`,
  item.eventDate ? `${opportunityUi.cards.eventLabel}: ${item.eventDate}` : "",
  item.location ? `${opportunityUi.dialog.locationLabel}: ${item.location}` : "",
  "",
  detailText(item),
  "",
  item.sourceUrl
].filter(Boolean).join("\n");

const forwardHref = (item: typeof items[number]) => {
  const details = [
    item.title,
    "",
    `Source: ${item.source}`,
    `Type: ${item.type}`,
    item.deadline ? `${opportunityUi.dialog.deadlineFallback}: ${item.deadline}` : `${opportunityUi.dialog.deadlineFallback}: ${opportunityUi.cards.rollingLabel} / see source`,
    item.location ? `${opportunityUi.dialog.locationLabel}: ${item.location}` : "",
    item.eventDate ? `${opportunityUi.cards.eventLabel}: ${item.eventDate}` : "",
    "",
    detailText(item),
    "",
    item.sourceUrl
  ].filter(Boolean);

  return `mailto:?subject=${encodeURIComponent(`Opportunity: ${item.title}`)}&body=${encodeURIComponent(details.join("\n"))}`;
};

const suggestSourceHref = `mailto:${contact.email}?subject=${encodeURIComponent(opportunityUi.sourceSection.suggestEmailSubject)}&body=${encodeURIComponent(opportunityUi.sourceSection.suggestEmailBody)}`;
---

<BaseLayout title={`${opportunityUi.metaTitle} | ${identity.title}`} description={opportunityUi.metaDescription}>
  <a class="skip-link" href="#opportunity-main">{opportunityUi.skipLinkText}</a>

  <header class="site-header">
    <a class="brand" href="/" aria-label={`${identity.title} home`}>
      <img src="/assets/images/third-sophistic.png" alt="" width="48" height="48" />
      <span>
        <strong>{identity.title}</strong>
        <small>{identity.subtitle}</small>
      </span>
    </a>
    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav class="site-nav" id="site-nav" aria-label={opportunityUi.navigationLabel}>
      {opportunityUi.navLinks.map((link) => <a href={link.url}>{link.label}</a>)}
    </nav>
  </header>

  <main id="opportunity-main">
    <section class="opportunity-hero" aria-labelledby="opportunity-title">
      <p class="eyebrow">{opportunities.summary.kicker}</p>
      <h1 id="opportunity-title">{opportunities.summary.title}</h1>
      <p class="dek">{opportunities.summary.text}</p>

      <div class="opportunity-stats" aria-label={opportunityUi.stats.ariaLabel}>
        <div>
          <span>{opportunityUi.stats.openCallsLabel}</span>
          <strong>{items.length}</strong>
        </div>
        <div>
          <span>{opportunityUi.stats.urgentLabel}</span>
          <strong>{urgentCount}</strong>
        </div>
        <div>
          <span>{opportunityUi.stats.soonLabel}</span>
          <strong>{soonCount}</strong>
        </div>
        <div>
          <span>{opportunityUi.stats.sourcesLabel}</span>
          <strong>{sources.items.length}</strong>
        </div>
        <div>
          <span>{opportunityUi.stats.newLabel}</span>
          <strong id="opportunity-new-count">0</strong>
        </div>
      </div>
    </section>

    <section class="opportunity-purposes" aria-label={opportunityUi.purposeSection.ariaLabel}>
      <div>
        <p class="eyebrow">{opportunityUi.purposeSection.kicker}</p>
        <h2>{opportunityUi.purposeSection.title}</h2>
      </div>
      <div class="opportunity-purpose-list">
        {purposeOptions.map((purpose) => (
          <button
            type="button"
            data-purpose-filter
            data-filter-type={purpose.filterType}
            data-filter-field={purpose.filterField}
            data-filter-query={purpose.filterQuery}
          >
            <strong>{purpose.label}</strong>
            <span>{purpose.text}</span>
          </button>
        ))}
      </div>
    </section>

    <section class="opportunity-tools" aria-label={opportunityUi.filters.ariaLabel}>
      <label>
        {opportunityUi.filters.searchLabel}
        <input id="opportunity-search" type="search" placeholder={opportunityUi.filters.searchPlaceholder} />
      </label>
      <label>
        {opportunityUi.filters.fieldLabel}
        <select id="opportunity-field">
          <option value="">{opportunityUi.filters.allFieldsLabel}</option>
          {fieldOptions.map((field) => <option value={field}>{field}</option>)}
        </select>
      </label>
      <label>
        {opportunityUi.filters.typeLabel}
        <select id="opportunity-type">
          <option value="">{opportunityUi.filters.allTypesLabel}</option>
          {typeOptions.map((type) => <option value={type}>{type}</option>)}
        </select>
      </label>
      <label>
        {opportunityUi.filters.sortLabel}
        <select id="opportunity-sort">
          {opportunityUi.filters.sortOptions.map((option) => <option value={option.value}>{option.label}</option>)}
        </select>
      </label>
      <div class="opportunity-new-filter" aria-label={opportunityUi.filters.newButtonLabel}>
        <button id="opportunity-new-filter" type="button" aria-pressed="false">
          {opportunityUi.filters.newButtonLabel}
          <span id="opportunity-new-filter-count">0</span>
        </button>
      </div>
      <div class="opportunity-save-filter" aria-label={opportunityUi.filters.savedButtonLabel}>
        <button id="opportunity-saved-filter" type="button" aria-pressed="false">
          {opportunityUi.filters.savedButtonLabel}
          <span id="opportunity-saved-count">0</span>
        </button>
      </div>
      {mappedOpportunities.length > 0 && (
        <div class="opportunity-map-filter" aria-label={opportunityUi.filters.mapButtonLabel}>
          <button id="opportunity-map-toggle" type="button" aria-expanded="false" aria-controls="opportunity-map-view">
            {opportunityUi.filters.mapButtonLabel}
            <span>{physicalMapPlaces.length}</span>
          </button>
        </div>
      )}
    </section>

    {mappedOpportunities.length > 0 && (
      <section class="opportunity-map" id="opportunity-map-view" aria-labelledby="opportunity-map-title" hidden>
        <div class="opportunity-map__heading">
          <div>
            <p class="eyebrow">{opportunityUi.map.kicker}</p>
            <h2 id="opportunity-map-title">{opportunityUi.map.title}</h2>
            <p>{opportunityUi.map.text}</p>
          </div>
          <div class="opportunity-map__summary">
            <span>{physicalMapPlaces.length} {opportunityUi.map.locationsSuffix}</span>
            <span>{physicalMapOpportunities.length} {opportunityUi.map.mappedCallsSuffix}</span>
            {virtualMapCount > 0 && <span>{virtualMapCount} {opportunityUi.map.virtualSuffix}</span>}
          </div>
        </div>

        <div class="opportunity-map__layout">
          <div class="opportunity-map__canvas" aria-label={opportunityUi.map.canvasLabel}>
            <div
              class="opportunity-map__real"
              id="opportunity-map-canvas"
              data-map-places={physicalMapPlacesJson}
            ></div>
            <div class="opportunity-map__loading" data-map-loading>
              <strong>{opportunityUi.map.loadingTitle}</strong>
              <span>{opportunityUi.map.loadingText}</span>
            </div>
          </div>

          <div class="opportunity-map__list" aria-label={opportunityUi.map.listLabel}>
            {
              physicalMapPlaces.map((place) => (
                <article class="opportunity-map__item" data-map-card={place.id}>
                  <span>{place.items.length} mapped {place.items.length === 1 ? opportunityUi.map.callSingular : opportunityUi.map.callPlural}</span>
                  <h3>{place.label}</h3>
                  <div class="opportunity-map__calls">
                    {
                      place.items.slice(0, 5).map((entry) => (
                        <a href={entry.item.sourceUrl} target="_blank" rel="noreferrer">
                          <strong>{entry.item.title}</strong>
                          <small>
                            {entry.item.eventDate ? `${opportunityUi.cards.eventLabel} ${formatShortDate(entry.item.eventDate)}` : opportunityUi.map.eventDateFallback}
                            {entry.item.deadline ? ` / ${formatDeadlineLabel(entry.item.deadlineType, entry.item.type)} ${formatShortDate(entry.item.deadline)}` : ` / ${opportunityUi.map.rollingDeadlineLabel}`}
                          </small>
                        </a>
                      ))
                    }
                    {place.items.length > 5 && <p>{place.items.length - 5} more {place.items.length - 5 === 1 ? opportunityUi.map.callSingular : opportunityUi.map.callPlural} {opportunityUi.map.moreAtLocationSuffix}</p>}
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>
    )}

    <section class="opportunity-results" aria-live="polite">
      <div class="opportunity-results__bar">
        <p><span id="opportunity-count">{items.length}</span> {opportunityUi.results.countSuffix}</p>
        <span>{opportunityUi.results.updatedPrefix} {opportunities.updated}</span>
      </div>

      <div class="opportunity-list" id="opportunity-list">
        {
          groups.map((group) => (
            <section class="opportunity-group" data-opportunity-group>
              <div class="opportunity-group__heading">
                <div>
                  <h2>
                    {group.id === "due-soon" ? (
                      <span data-group-title>{group.title}</span>
                    ) : (
                      <button
                        type="button"
                        data-group-filter
                        data-filter-type={group.filterType}
                        data-filter-field={group.filterField}
                        data-filter-query={group.filterQuery}
                        data-group-title
                      >
                        {group.title}
                      </button>
                    )}
                  </h2>
                  <p data-group-text>{group.text}</p>
                </div>
                <div class="opportunity-group__side">
                  <div class="opportunity-saved-note" data-saved-note hidden>
                    <p>{opportunityUi.results.savedNote}</p>
                    <div>
                      <button type="button" data-copy-saved>{opportunityUi.results.copySavedLabel}</button>
                      <a href="#" data-email-saved>{opportunityUi.results.emailSavedLabel}</a>
                    </div>
                  </div>
                  <span data-group-count>{group.items.length}</span>
                </div>
              </div>
              <div class="opportunity-group__items">
                {
                  group.items.map((item) => (
                    <article
                      class:list={["opportunity-card", `is-${item.urgency}`]}
                      data-search={item.searchText}
                      data-fields={item.fields.join("|")}
                      data-type={item.type}
                      data-id={item.sourceUrl}
                      data-title={item.title.toLowerCase()}
                      data-days={typeof item.days === "number" ? item.days : 9999}
                      data-score={item.score || 0}
                      data-copy-text={copyDetails(item)}
                    >
                      <div class="opportunity-date-strip">
                        {item.eventDate && (
                          <time class="opportunity-date-box" datetime={item.eventDate}>
                            <span>{opportunityUi.cards.eventLabel}</span>
                            <strong>{formatShortDate(item.eventDate)}</strong>
                          </time>
                        )}
                        <time class="opportunity-date-box" datetime={item.deadline || undefined}>
                          <span>{formatDeadlineLabel(item.deadlineType, item.type)}</span>
                          <strong>{item.deadline ? formatShortDate(item.deadline) : opportunityUi.cards.rollingLabel}</strong>
                        </time>
                        <span class:list={["opportunity-date-box", "opportunity-date-box--countdown", `is-${item.urgency}`]}>
                          <span>{opportunityUi.cards.daysLeftLabel}</span>
                          <strong>{formatDaysLeft(item.days)}</strong>
                        </span>
                        <div class="opportunity-card__actions">
                          <a class="opportunity-forward" href={forwardHref(item)} aria-label={`Forward opportunity: ${item.title}`}>
                            {opportunityUi.actions.forwardLabel}
                          </a>
                          <button class="opportunity-save" type="button" data-save-opportunity aria-pressed="false">
                            {opportunityUi.actions.saveLabel}
                          </button>
                          <button
                            class="opportunity-detail"
                            type="button"
                            data-detail-opportunity
                            data-detail-title={item.title}
                            data-detail-source={`${item.source} / ${item.type}`}
                            data-detail-deadline-label={formatDeadlineLabel(item.deadlineType, item.type)}
                            data-detail-deadline={item.deadline || opportunityUi.cards.sourceListedFallback}
                            data-detail-days={formatDaysLeft(item.days)}
                            data-detail-event={item.eventDate || ""}
                            data-detail-location={item.location || opportunityUi.cards.onlineFallback}
                            data-detail-excerpt={detailText(item)}
                            data-detail-url={item.sourceUrl}
                            data-detail-fields={item.fields.join("|")}
                            data-detail-reason={matchReasons(item)}
                            data-detail-checklist={detailChecklist(item).join("|")}
                          >
                            {opportunityUi.actions.detailsLabel}
                          </button>
                          <button class="opportunity-copy" type="button" data-copy-opportunity data-copy-text={copyDetails(item)}>
                            {opportunityUi.actions.copyLabel}
                          </button>
                        </div>
                      </div>
                      <div class="opportunity-card__body">
                        <div>
                          <div class="opportunity-card__kicker">
                            <p class="opportunity-source">{item.source} / {item.type}</p>
                            <span class="opportunity-new" data-new-badge hidden>{opportunityUi.actions.newBadgeLabel}</span>
                          </div>
                          <h3><a href={item.sourceUrl} target="_blank" rel="noreferrer">{item.title}</a></h3>
                          <p>{displayPreview(item.excerpt)}</p>
                          <div class="opportunity-meta">
                            <span>{item.location || opportunityUi.cards.onlineFallback}</span>
                            {item.eventDate && <time datetime={item.eventDate}>{opportunityUi.cards.eventLabel}: {item.eventDate}</time>}
                          </div>
                        </div>
                      </div>
                      <div class="opportunity-tags" aria-label={opportunityUi.cards.fieldsLabel}>
                        {signalTags(item).map((field) => (
                          <button type="button" data-field-filter={field} data-field-query={signalQuery(field)}>{field}</button>
                        ))}
                      </div>
                    </article>
                  ))
                }
              </div>
            </section>
          ))
        }
      </div>
      <p class="opportunity-empty" id="opportunity-empty" hidden>{opportunityUi.results.emptyText}</p>
      <div class="opportunity-more">
        <button id="opportunity-more" type="button">{opportunityUi.results.showMoreLabel}</button>
      </div>
    </section>

    <dialog class="opportunity-dialog" id="opportunity-dialog" aria-labelledby="opportunity-dialog-title">
      <div class="opportunity-dialog__panel">
        <button class="opportunity-dialog__close" type="button" data-dialog-close aria-label={opportunityUi.dialog.closeLabel}>{opportunityUi.dialog.closeLabel}</button>
        <p class="opportunity-dialog__source" id="opportunity-dialog-source"></p>
        <h2 id="opportunity-dialog-title"></h2>
        <div class="opportunity-dialog__facts" aria-label={opportunityUi.dialog.detailsLabel}>
          <div>
            <span id="opportunity-dialog-deadline-label">{opportunityUi.dialog.deadlineFallback}</span>
            <strong id="opportunity-dialog-deadline"></strong>
          </div>
          <div>
            <span>{opportunityUi.dialog.daysLeftLabel}</span>
            <strong id="opportunity-dialog-days"></strong>
          </div>
          <div id="opportunity-dialog-event-wrap">
            <span>{opportunityUi.dialog.eventLabel}</span>
            <strong id="opportunity-dialog-event"></strong>
          </div>
          <div>
            <span>{opportunityUi.dialog.locationLabel}</span>
            <strong id="opportunity-dialog-location"></strong>
          </div>
        </div>
        <p class="opportunity-dialog__reason" id="opportunity-dialog-reason"></p>
        <div class="opportunity-dialog__checklist" id="opportunity-dialog-checklist" hidden>
          <h3>{opportunityUi.dialog.quickScanTitle}</h3>
          <ul></ul>
        </div>
        <p class="opportunity-dialog__excerpt" id="opportunity-dialog-excerpt"></p>
        <div class="opportunity-dialog__fields" id="opportunity-dialog-fields" aria-label={opportunityUi.dialog.fieldsLabel}></div>
        <div class="opportunity-dialog__actions">
          <a id="opportunity-dialog-link" href="#" target="_blank" rel="noreferrer">{opportunityUi.dialog.openSourceLabel}</a>
          <button type="button" data-dialog-close>{opportunityUi.dialog.doneLabel}</button>
        </div>
      </div>
    </dialog>

    <section class="section source-section" aria-labelledby="source-title">
      <div class="section-kicker">{opportunityUi.sourceSection.kicker}</div>
      <div class="section-heading">
        <h2 id="source-title">{opportunityUi.sourceSection.title}</h2>
        <p>{opportunityUi.sourceSection.text}</p>
      </div>

      <div class="feed-note">
        <div>
          <h3>{opportunityUi.sourceSection.feedTitle}</h3>
          <p>{opportunityUi.sourceSection.feedText}</p>
        </div>
        <a href={suggestSourceHref}>{opportunityUi.sourceSection.suggestSourceLabel}</a>
      </div>

      <div class="source-grid">
        {
          activeSources.map((source) => (
            <a class="source-card" href={source.url} target="_blank" rel="noreferrer">
              <span>{source.type}</span>
              <strong>{source.name}</strong>
              <small>{source.cadence} {opportunityUi.sourceSection.cadenceSuffix}</small>
            </a>
          ))
        }
      </div>

      {watchSources.length > 0 && (
        <div class="watch-source-block">
          <div class="watch-source-heading">
            <h3>{opportunityUi.sourceSection.watchlistTitle}</h3>
            <p>{opportunityUi.sourceSection.watchlistText}</p>
          </div>
          <div class="watch-source-list">
            {
              watchSources.map((source) => (
                <a href={source.url} target="_blank" rel="noreferrer">
                  <small>{opportunityUi.sourceSection.watchSourceLabel}</small>
                  <strong>{source.name}</strong>
                  <span>{source.type}</span>
                </a>
              ))
            }
          </div>
        </div>
      )}
    </section>
  </main>

  <script type="application/json" id="opportunity-ui-config" set:html={opportunityUiJson}></script>
  <script is:inline>
    const ui = JSON.parse(document.querySelector("#opportunity-ui-config")?.textContent || "{}");
    const search = document.querySelector("#opportunity-search");
    const field = document.querySelector("#opportunity-field");
    const type = document.querySelector("#opportunity-type");
    const sort = document.querySelector("#opportunity-sort");
    const cards = Array.from(document.querySelectorAll(".opportunity-card"));
    const groups = Array.from(document.querySelectorAll("[data-opportunity-group]"));
    const fieldButtons = Array.from(document.querySelectorAll("[data-field-filter]"));
    const groupButtons = Array.from(document.querySelectorAll("[data-group-filter]"));
    const purposeButtons = Array.from(document.querySelectorAll("[data-purpose-filter]"));
    const saveButtons = Array.from(document.querySelectorAll("[data-save-opportunity]"));
    const copyButtons = Array.from(document.querySelectorAll("[data-copy-opportunity]"));
    const detailButtons = Array.from(document.querySelectorAll("[data-detail-opportunity]"));
    const dialog = document.querySelector("#opportunity-dialog");
    const dialogCloseButtons = Array.from(document.querySelectorAll("[data-dialog-close]"));
    const dialogTitle = document.querySelector("#opportunity-dialog-title");
    const dialogSource = document.querySelector("#opportunity-dialog-source");
    const dialogDeadlineLabel = document.querySelector("#opportunity-dialog-deadline-label");
    const dialogDeadline = document.querySelector("#opportunity-dialog-deadline");
    const dialogDays = document.querySelector("#opportunity-dialog-days");
    const dialogEventWrap = document.querySelector("#opportunity-dialog-event-wrap");
    const dialogEvent = document.querySelector("#opportunity-dialog-event");
    const dialogLocation = document.querySelector("#opportunity-dialog-location");
    const dialogExcerpt = document.querySelector("#opportunity-dialog-excerpt");
    const dialogReason = document.querySelector("#opportunity-dialog-reason");
    const dialogChecklist = document.querySelector("#opportunity-dialog-checklist");
    const dialogChecklistList = dialogChecklist?.querySelector("ul");
    const dialogFields = document.querySelector("#opportunity-dialog-fields");
    const dialogLink = document.querySelector("#opportunity-dialog-link");
    const newFilter = document.querySelector("#opportunity-new-filter");
    const newCount = document.querySelector("#opportunity-new-count");
    const newFilterCount = document.querySelector("#opportunity-new-filter-count");
    const savedFilter = document.querySelector("#opportunity-saved-filter");
    const savedCount = document.querySelector("#opportunity-saved-count");
    const mapToggle = document.querySelector("#opportunity-map-toggle");
    const mapView = document.querySelector("#opportunity-map-view");
    const mapCanvas = document.querySelector("#opportunity-map-canvas");
    const mapLoading = document.querySelector("[data-map-loading]");
    const mapCards = Array.from(document.querySelectorAll("[data-map-card]"));
    const savedNotes = Array.from(document.querySelectorAll("[data-saved-note]"));
    const copySavedButtons = Array.from(document.querySelectorAll("[data-copy-saved]"));
    const emailSavedLinks = Array.from(document.querySelectorAll("[data-email-saved]"));
    const empty = document.querySelector("#opportunity-empty");
    const more = document.querySelector("#opportunity-more");
    const count = document.querySelector("#opportunity-count");
    const pageSize = 10;
    const savedStorageKey = "thirdSophisticSavedOpportunities";
    const seenStorageKey = "thirdSophisticSeenOpportunities";
    let visibleLimit = pageSize;
    let showSavedOnly = false;
    let showNewOnly = false;
    let savedItems = new Set();

    const escapeDialogHtml = (value) => String(value || "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");

    const linkedDialogText = (value) => {
      const escaped = escapeDialogHtml(value);
      return escaped.replace(/\b((?:https?:\/\/|www\.)[^\s<]+|[a-z0-9.-]+\.(?:com|org|net|edu|gov|io|co|uk|ca|au|de|fr|it|es|nl|se|no|dk|fi|ch|jp|ai|app|art|film|media|press|info|events|festival|museum)(?:\/[^\s<]*)?)/gi, (match) => {
        const trailing = match.match(/[),.;:!?]+$/)?.[0] || "";
        const clean = trailing ? match.slice(0, -trailing.length) : match;
        const href = clean.startsWith("http://") || clean.startsWith("https://") ? clean : `https://${clean}`;
        return `<a href="${href}" target="_blank" rel="noreferrer">${clean}</a>${trailing}`;
      });
    };
    let seenItems = new Set();
    let hasSeenSnapshot = false;

    const loadSavedItems = () => {
      try {
        const parsed = JSON.parse(window.localStorage.getItem(savedStorageKey) || "[]");
        savedItems = new Set(Array.isArray(parsed) ? parsed.filter(Boolean) : []);
      } catch {
        savedItems = new Set();
      }
    };

    const storeSavedItems = () => {
      window.localStorage.setItem(savedStorageKey, JSON.stringify(Array.from(savedItems)));
    };

    const loadSeenItems = () => {
      try {
        const parsed = JSON.parse(window.localStorage.getItem(seenStorageKey) || "[]");
        hasSeenSnapshot = Array.isArray(parsed) && parsed.length > 0;
        seenItems = new Set(Array.isArray(parsed) ? parsed.filter(Boolean) : []);
      } catch {
        hasSeenSnapshot = false;
        seenItems = new Set();
      }
    };

    const storeSeenItems = () => {
      const ids = cards.map((card) => card.dataset.id).filter(Boolean);
      window.localStorage.setItem(seenStorageKey, JSON.stringify(ids));
    };

    const updateNewUi = () => {
      let newTotal = 0;
      cards.forEach((card) => {
        const isNew = hasSeenSnapshot && !seenItems.has(card.dataset.id);
        if (isNew) newTotal += 1;
        card.dataset.new = isNew ? "true" : "false";
        const badge = card.querySelector("[data-new-badge]");
        if (badge) badge.hidden = !isNew;
      });
      if (newCount) newCount.textContent = String(newTotal);
      if (newFilterCount) newFilterCount.textContent = String(newTotal);
      if (newFilter) {
        newFilter.setAttribute("aria-pressed", String(showNewOnly));
        newFilter.classList.toggle("is-active", showNewOnly);
        newFilter.disabled = newTotal === 0 && !showNewOnly;
      }
    };

    const sortGroupCards = () => {
      const selectedSort = sort.value;
      groups.forEach((group) => {
        const container = group.querySelector(".opportunity-group__items");
        const groupCards = Array.from(group.querySelectorAll(".opportunity-card"));
        groupCards
          .sort((a, b) => {
            if (selectedSort === "new") {
              const aNew = a.dataset.new === "true" ? 0 : 1;
              const bNew = b.dataset.new === "true" ? 0 : 1;
              if (aNew !== bNew) return aNew - bNew;
            }
            if (selectedSort === "fit") {
              const scoreDiff = Number(b.dataset.score || 0) - Number(a.dataset.score || 0);
              if (scoreDiff !== 0) return scoreDiff;
            }
            if (selectedSort === "title") {
              return String(a.dataset.title || "").localeCompare(String(b.dataset.title || ""));
            }
            return Number(a.dataset.days || 9999) - Number(b.dataset.days || 9999);
          })
          .forEach((card) => container.appendChild(card));
      });
    };

    const updateSavedUi = () => {
      cards.forEach((card) => {
        const isSaved = savedItems.has(card.dataset.id);
        card.dataset.saved = isSaved ? "true" : "false";
        const button = card.querySelector("[data-save-opportunity]");
        if (!button) return;
        button.setAttribute("aria-pressed", String(isSaved));
        button.textContent = isSaved ? ui.actions.savedLabel : ui.actions.saveLabel;
      });

      savedCount.textContent = String(savedItems.size);
      savedFilter.setAttribute("aria-pressed", String(showSavedOnly));
      savedFilter.classList.toggle("is-active", showSavedOnly);
      savedNotes.forEach((note) => {
        note.hidden = !showSavedOnly;
      });
    };

    const savedListText = () => cards
      .filter((card) => savedItems.has(card.dataset.id))
      .map((card) => card.dataset.copyText || card.querySelector("h3")?.textContent?.trim() || "")
      .filter(Boolean)
      .join("\n\n---\n\n");

    const updateSavedActions = () => {
      const text = savedListText();
      const hasSaved = Boolean(text);
      copySavedButtons.forEach((button) => {
        button.disabled = !hasSaved;
      });
      emailSavedLinks.forEach((link) => {
        link.toggleAttribute("aria-disabled", !hasSaved);
        link.href = hasSaved
          ? `mailto:?subject=${encodeURIComponent(ui.results.savedGroupTitle)}&body=${encodeURIComponent(text)}`
          : "#";
      });
    };

    const loadExternalAsset = (kind, url) => new Promise((resolve, reject) => {
      const selector = kind === "script" ? `script[src="${url}"]` : `link[href="${url}"]`;
      const existing = document.querySelector(selector);
      if (existing) {
        resolve(existing);
        return;
      }

      const element = kind === "script" ? document.createElement("script") : document.createElement("link");
      if (kind === "script") {
        element.src = url;
        element.async = true;
      } else {
        element.rel = "stylesheet";
        element.href = url;
      }
      element.addEventListener("load", () => resolve(element), { once: true });
      element.addEventListener("error", () => reject(new Error(`Could not load ${url}`)), { once: true });
      document.head.appendChild(element);
    });

    const loadFirstAvailableScript = async (urls) => {
      for (const url of urls) {
        try {
          return await loadExternalAsset("script", url);
        } catch {
          // Try the next CDN.
        }
      }
      throw new Error("Could not load map script");
    };

    const selectMapPlace = (id) => {
      const card = mapCards.find((entry) => entry.dataset.mapCard === id);
      mapCards.forEach((entry) => entry.classList.toggle("is-active", entry === card));
      card?.scrollIntoView({ behavior: "smooth", block: "nearest" });
    };

    const setMapStatus = (title, text) => {
      if (!mapLoading) return;
      mapLoading.hidden = false;
      const titleElement = mapLoading.querySelector("strong");
      const textElement = mapLoading.querySelector("span");
      if (titleElement) titleElement.textContent = title;
      if (textElement) textElement.textContent = text;
    };

    const initializeRadarMap = async () => {
      if (!mapCanvas || mapCanvas.dataset.mapReady === "true" || mapCanvas.dataset.mapReady === "loading") return;
      mapCanvas.dataset.mapReady = "loading";
      setMapStatus(ui.map.loadingTitle, ui.map.loadingText);

      try {
        loadExternalAsset("style", "https://unpkg.com/maplibre-gl@5.24.0/dist/maplibre-gl.css").catch(() => {});
        await loadFirstAvailableScript([
          "https://unpkg.com/maplibre-gl@5.24.0/dist/maplibre-gl.js",
          "https://cdn.jsdelivr.net/npm/maplibre-gl@5.24.0/dist/maplibre-gl.js"
        ]);

        const places = JSON.parse(mapCanvas.dataset.mapPlaces || "[]");
        const map = new maplibregl.Map({
          container: mapCanvas,
          style: "https://tiles.openfreemap.org/styles/positron",
          center: [-18, 24],
          zoom: 1.35,
          attributionControl: true
        });

        map.addControl(new maplibregl.NavigationControl({ showCompass: false }), "top-right");
        map.scrollZoom.disable();
        requestAnimationFrame(() => map.resize());

        const bounds = new maplibregl.LngLatBounds();
        places.forEach((place) => {
          bounds.extend([place.lng, place.lat]);
          const markerElement = document.createElement("button");
          markerElement.type = "button";
          markerElement.className = "opportunity-map__marker";
          const markerCount = document.createElement("strong");
          markerCount.textContent = String(place.count);
          const markerLabel = document.createElement("span");
          markerLabel.textContent = place.label;
          markerElement.append(markerCount, markerLabel);
          markerElement.setAttribute("aria-label", `${place.label}: ${place.count} mapped ${place.count === 1 ? ui.map.markerOpportunitySingular : ui.map.markerOpportunityPlural}`);
          markerElement.addEventListener("click", () => {
            selectMapPlace(place.id);
          });

          const popupContent = document.createElement("div");
          popupContent.className = "opportunity-map__popup";
          const popupHeader = document.createElement("div");
          popupHeader.className = "opportunity-map__popup-header";
          const popupTitle = document.createElement("strong");
          popupTitle.textContent = place.label;
          const popupCount = document.createElement("span");
          popupCount.textContent = `${place.count} ${place.count === 1 ? ui.map.callSingular : ui.map.callPlural}`;
          popupHeader.append(popupTitle, popupCount);
          const popupList = document.createElement("ul");
          popupList.setAttribute("aria-label", `${ui.map.popupListLabelPrefix} ${place.label}`);
          place.calls.slice(0, 3).forEach((call) => {
            const popupItem = document.createElement("li");
            const popupLink = document.createElement("a");
            popupLink.href = call.url;
            popupLink.target = "_blank";
            popupLink.rel = "noreferrer";
            popupLink.textContent = String(call.title);
            popupItem.appendChild(popupLink);
            popupList.appendChild(popupItem);
          });
          if (place.count > place.calls.length) {
            const popupMore = document.createElement("p");
            popupMore.textContent = `${place.count - place.calls.length} ${ui.map.moreInListSuffix}`;
            popupContent.append(popupHeader, popupList, popupMore);
          } else {
            popupContent.append(popupHeader, popupList);
          }

          new maplibregl.Marker({ element: markerElement, anchor: "center" })
            .setLngLat([place.lng, place.lat])
            .setPopup(new maplibregl.Popup({ offset: 18 }).setDOMContent(popupContent))
            .addTo(map);
        });

        if (places.length > 1) {
          map.fitBounds(bounds, { padding: 58, maxZoom: 4.2, duration: 900 });
        }

        const mapPaintTimeout = window.setTimeout(() => {
          if (mapCanvas.dataset.mapReady !== "true") {
            mapCanvas.dataset.mapReady = "error";
            setMapStatus(ui.map.unavailableTitle, ui.map.unavailableText);
          }
        }, 6000);

        map.once("idle", () => {
          window.clearTimeout(mapPaintTimeout);
          mapCanvas.dataset.mapReady = "true";
          if (mapLoading) mapLoading.hidden = true;
        });

        map.once("error", () => {
          window.clearTimeout(mapPaintTimeout);
          mapCanvas.dataset.mapReady = "error";
          setMapStatus(ui.map.unavailableTitle, ui.map.unavailableText);
        });

        window.radarMap = map;
      } catch {
        mapCanvas.dataset.mapReady = "error";
        setMapStatus(ui.map.unavailableTitle, ui.map.unavailableText);
      }
    };

    const filterOpportunities = () => {
      const query = search.value.trim().toLowerCase();
      const queryTerms = query.split(/\s+/).filter(Boolean);
      const selectedField = field.value;
      const selectedType = type.value;
      let matched = 0;
      let visible = 0;
      let firstVisibleGroup = null;

      sortGroupCards();

      cards.forEach((card) => {
        const matchesQuery = !queryTerms.length || queryTerms.every((term) => card.dataset.search.includes(term));
        const matchesField = !selectedField || card.dataset.fields.split("|").includes(selectedField);
        const matchesType = !selectedType || card.dataset.type === selectedType;
        const matchesSaved = !showSavedOnly || savedItems.has(card.dataset.id);
        const matchesNew = !showNewOnly || card.dataset.new === "true";
        const matches = matchesQuery && matchesField && matchesType && matchesSaved && matchesNew;
        const show = matches && matched < visibleLimit;

        card.hidden = !show;
        if (matches) matched += 1;
        if (show) visible += 1;
      });

      groups.forEach((group) => {
        const groupCards = Array.from(group.querySelectorAll(".opportunity-card"));
        const visibleGroupCards = groupCards.filter((card) => !card.hidden);
        group.hidden = visibleGroupCards.length === 0;
        group.classList.remove("is-saved-primary", "is-saved-secondary");
        if (showSavedOnly && visibleGroupCards.length > 0) {
          if (!firstVisibleGroup) {
            firstVisibleGroup = group;
            group.classList.add("is-saved-primary");
          } else {
            group.classList.add("is-saved-secondary");
          }
        }

        const groupTitle = group.querySelector("[data-group-title]");
        const groupText = group.querySelector("[data-group-text]");
        if (groupTitle) {
          groupTitle.textContent = group.classList.contains("is-saved-primary") ? ui.results.savedGroupTitle : groupTitle.dataset.originalTitle || groupTitle.textContent;
        }
        if (groupText) {
          groupText.textContent = group.classList.contains("is-saved-primary")
            ? ui.results.savedGroupText
            : groupText.dataset.originalText || groupText.textContent;
        }

        const groupCount = group.querySelector("[data-group-count]");
        if (groupCount) {
          const matchedGroupCards = groupCards.filter((card) => {
            const matchesQuery = !queryTerms.length || queryTerms.every((term) => card.dataset.search.includes(term));
            const matchesField = !selectedField || card.dataset.fields.split("|").includes(selectedField);
            const matchesType = !selectedType || card.dataset.type === selectedType;
            const matchesSaved = !showSavedOnly || savedItems.has(card.dataset.id);
            const matchesNew = !showNewOnly || card.dataset.new === "true";
            return matchesQuery && matchesField && matchesType && matchesSaved && matchesNew;
          });
          groupCount.textContent = String(group.classList.contains("is-saved-primary") ? matched : matchedGroupCards.length);
        }
      });

      count.textContent = String(matched);
      empty.hidden = matched > 0;
      empty.textContent = showSavedOnly
        ? ui.results.emptySavedText
        : showNewOnly
          ? ui.results.emptyNewText
        : ui.results.emptyFilteredText;
      more.hidden = matched <= visibleLimit;
      more.textContent = `${ui.results.showMorePrefix} ${Math.min(pageSize, Math.max(matched - visibleLimit, 0))} ${ui.results.showMoreSuffix}`;
    };

    const resetLimit = () => {
      visibleLimit = pageSize;
      filterOpportunities();
    };

    groups.forEach((group) => {
      const groupTitle = group.querySelector("[data-group-title]");
      const groupText = group.querySelector("[data-group-text]");
      if (groupTitle) groupTitle.dataset.originalTitle = groupTitle.textContent;
      if (groupText) groupText.dataset.originalText = groupText.textContent;
    });

    [search, field, type, sort].forEach((control) => control.addEventListener("input", resetLimit));

    savedFilter.addEventListener("click", () => {
      showSavedOnly = !showSavedOnly;
      visibleLimit = pageSize;
      updateSavedUi();
      filterOpportunities();
    });

    newFilter.addEventListener("click", () => {
      showNewOnly = !showNewOnly;
      visibleLimit = pageSize;
      updateNewUi();
      filterOpportunities();
    });

    if (mapToggle && mapView) {
      mapToggle.addEventListener("click", () => {
        const isOpening = mapView.hidden;
        mapView.hidden = !isOpening;
        mapToggle.setAttribute("aria-expanded", String(isOpening));
        mapToggle.classList.toggle("is-active", isOpening);
        if (isOpening) {
          mapView.scrollIntoView({ behavior: "smooth", block: "start" });
          initializeRadarMap();
        }
      });
    }

    saveButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const card = button.closest(".opportunity-card");
        const id = card?.dataset.id;
        if (!id) return;
        if (savedItems.has(id)) {
          savedItems.delete(id);
        } else {
          savedItems.add(id);
        }
        storeSavedItems();
        updateSavedUi();
        updateSavedActions();
        filterOpportunities();
      });
    });

    copySavedButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        const original = button.textContent;
        try {
          await navigator.clipboard.writeText(savedListText());
          button.textContent = ui.actions.copiedLabel;
        } catch {
          button.textContent = ui.actions.copyUnavailableLabel;
        }
        window.setTimeout(() => {
          button.textContent = original;
        }, 1800);
      });
    });

    copyButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        const original = button.textContent;
        const text = button.dataset.copyText || "";
        try {
          await navigator.clipboard.writeText(text);
          button.textContent = ui.actions.copiedLabel;
        } catch {
          button.textContent = ui.actions.copyUnavailableLabel;
        }
        window.setTimeout(() => {
          button.textContent = original;
        }, 1800);
      });
    });

    detailButtons.forEach((button) => {
      button.addEventListener("click", () => {
        dialogTitle.textContent = button.dataset.detailTitle || "";
        dialogSource.textContent = button.dataset.detailSource || "";
        dialogDeadlineLabel.textContent = button.dataset.detailDeadlineLabel || ui.dialog.deadlineFallback;
        dialogDeadline.textContent = button.dataset.detailDeadline || "";
        dialogDays.textContent = button.dataset.detailDays || "";
        dialogLocation.textContent = button.dataset.detailLocation || "";
        dialogReason.textContent = button.dataset.detailReason || "";
        dialogExcerpt.innerHTML = linkedDialogText(button.dataset.detailExcerpt || "");
        dialogLink.href = button.dataset.detailUrl || "#";

        dialogChecklistList.textContent = "";
        const checklistItems = (button.dataset.detailChecklist || "").split("|").filter(Boolean);
        dialogChecklist.hidden = checklistItems.length === 0;
        checklistItems.forEach((item) => {
          const listItem = document.createElement("li");
          listItem.textContent = item;
          dialogChecklistList.appendChild(listItem);
        });

        const eventDate = button.dataset.detailEvent || "";
        dialogEventWrap.hidden = !eventDate;
        dialogEvent.textContent = eventDate;

        dialogFields.textContent = "";
        (button.dataset.detailFields || "")
          .split("|")
          .filter(Boolean)
          .forEach((fieldName) => {
            const fieldPill = document.createElement("span");
            fieldPill.textContent = fieldName;
            dialogFields.appendChild(fieldPill);
          });

        if (typeof dialog.showModal === "function") {
          dialog.showModal();
        } else {
          dialog.setAttribute("open", "");
        }
      });
    });

    dialogCloseButtons.forEach((button) => {
      button.addEventListener("click", () => {
        dialog.close();
      });
    });

    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) dialog.close();
    });

    fieldButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const value = button.dataset.fieldFilter;
        const hasFieldOption = Array.from(field.options).some((option) => option.value === value);
        if (hasFieldOption) {
          field.value = value;
          search.value = "";
        } else {
          search.value = button.dataset.fieldQuery || value || "";
          field.value = "";
        }
        visibleLimit = pageSize;
        filterOpportunities();
        document.querySelector(".opportunity-tools").scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    [...groupButtons, ...purposeButtons].forEach((button) => {
      button.addEventListener("click", () => {
        search.value = button.dataset.filterQuery || "";
        field.value = button.dataset.filterField || "";
        type.value = button.dataset.filterType || "";
        showSavedOnly = false;
        showNewOnly = false;
        visibleLimit = pageSize;
        updateSavedUi();
        updateNewUi();
        filterOpportunities();
        document.querySelector(".opportunity-tools").scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    more.addEventListener("click", () => {
      visibleLimit += pageSize;
      filterOpportunities();
    });

    loadSavedItems();
    loadSeenItems();
    updateNewUi();
    updateSavedUi();
    updateSavedActions();
    filterOpportunities();
    storeSeenItems();
  </script>
</BaseLayout>
